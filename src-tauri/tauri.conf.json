{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TomaFiler",
  "version": "1.2.0",
  "identifier": "com.filer.app",
  "build": {
    "beforeDevCommand": "pnpm exec vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm exec tsc && pnpm exec vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TomaFiler",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "dragDropEnabled": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/32x32.png"
    ]
  }
}
